{
  "manifest_version": 3,
  "name": "EcoGuard",
  "version": "1.0.0",
  "description": "Track browsing carbon footprint and privacy risks.",
  "permissions": [
    "storage",
    "tabs",
    "activeTab"
  ],
  "background": {
    "service_worker": "background/background.js"
  },
  "action": {
    "default_popup": "popup/popup.html"
  }
}
